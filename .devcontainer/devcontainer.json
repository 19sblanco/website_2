{
  "name": "2.0 website (backend dev)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode",
      "userUid": "automatic",
      "userGid": "automatic"
    }
  },
  "remoteUser": "vscode",
  "forwardPorts": [5089, 5173, 3306],
  "postCreateCommand": "sudo chown -R vscode:vscode /workspace && dotnet restore \"src/backend/2.0 website.sln\"",
  "postStartCommand": "dotnet build \"src/backend/2.0 website.sln\" -clp:ErrorsOnly",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "dotnet.defaultSolution": "src/backend/2.0 website.sln"
      }
    }
  }
}
