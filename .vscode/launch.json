{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (.NET)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/backend/WebServer/WebServer.csproj",
      "launchConfigurationId": "TargetFramework=net10.0;http"
    },
    {
      "name": "Frontend (React)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/frontend",
      "preLaunchTask": "start-frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Dev",
      "configurations": ["Backend (.NET)", "Frontend (React)"]
    }
  ]
}
